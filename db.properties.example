#Database driver
db.driver=com.mysql.cj.jdbc.Driver

# Server connection (no database) — used to create the database on first run
db.serverUrl=jdbc:mysql://localhost:3306/?allowPublicKeyRetrieval=true

# Name of the database the app creates/uses
db.name=employees_database

# Full JDBC URL including the database
db.url=jdbc:mysql://localhost:3306/employees_database?allowPublicKeyRetrieval=true

# Use a MySQL account allowed to create databases on first run (e.g. root)
db.user=root
db.password=your_mysql_password
